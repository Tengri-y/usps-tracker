# 数据库配置
DATABASE_URL=sqlite:///usps_tracker.db
# DATABASE_URL=postgresql://user:password@localhost/usps_db

# =====================
# 代理配置
# =====================
PROXY_ENABLED=true
PROXY_ROTATION_STRATEGY=round_robin
PROXY_CHANGE_PER_REQUEST=true
PROXY_FALLBACK_ENABLED=true

# 代理列表（逗号分隔）
PROXY_LIST=http://proxy1.com:8080,http://proxy2.com:8080,http://proxy3.com:8080

# =====================
# 浏览器配置
# =====================
HEADLESS=true
BROWSER_TIMEOUT=30
BROWSER_WINDOW_WIDTH=1920
BROWSER_WINDOW_HEIGHT=1080
DISABLE_IMAGES=false

# =====================
# 爬虫配置
# =====================
REQUEST_DELAY_MIN=2
REQUEST_DELAY_MAX=5
RETRY_MAX=3
RETRY_BACKOFF=exponential
MAX_WORKERS=2

# =====================
# 日志配置
# =====================
LOG_LEVEL=INFO
LOG_FILE=logs/usps_tracker.log

# =====================
# USPS配置
# =====================
USPS_TRACKING_URL=https://tools.usps.com/go/TrackConfirmAction
USPS_TIMEOUT=30

# =====================
# 缓存配置
# =====================
CACHE_ENABLED=true
CACHE_TTL=3600
